# Algorand Network Configuration
VITE_ALGOD_URL=https://testnet-api.algonode.cloud
VITE_ALGOD_TOKEN=
VITE_INDEXER_URL=https://testnet-idx.algonode.cloud
VITE_INDEXER_TOKEN=

# Backend API Configuration
VITE_API_BASE_URL=http://localhost:5000/api

# Stripe Configuration (if using payments)
VITE_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key

# Strict Sign-off Status URL (optional)
# When set, the Release Evidence Center fetches the signoff-status.json artifact
# from this URL to display the current strict sign-off lane status.
# Example: https://artifacts.biatec.io/signoff-status.json
# Leave empty to show "not configured" state in the Release Evidence Center.
VITE_SIGNOFF_STATUS_URL=