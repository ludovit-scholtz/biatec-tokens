{
  "name": "biatec-tokens-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "generate-api": "swagger-typescript-api generate -p https://api.tokens.biatec.io/swagger/v1/swagger.json -o src/generated -n ApiClient.ts --axios",
    "check-typescript-errors-tsc": "npx tsc --noEmit",
    "check-typescript-errors-vue": "npx vue-tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test --reporter=line",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "test:e2e:journey-video": "set VIDEO_RECORDING=true && playwright test full-e2e-journey.spec.ts --grep \"should complete full journey\" --config playwright-video.config.ts"
  },
  "dependencies": {
    "@agoralabs-sh/avm-web-provider": "^1.7.0",
    "@algorandfoundation/algokit-utils": "^9.2.0",
    "@blockshake/defly-connect": "^1.2.1",
    "@heroicons/vue": "^2.2.0",
    "@perawallet/connect": "^1.5.0",
    "@txnlab/use-wallet-vue": "^4.5.0",
    "@walletconnect/modal": "^2.7.0",
    "@walletconnect/sign-client": "^2.23.4",
    "algorand-authentication-component-vue": "^2.0.6",
    "algosdk": "^3.5.2",
    "axios": "^1.13.4",
    "buffer": "^6.0.3",
    "ghost-cursor-playwright": "^2.1.0",
    "lute-connect": "^1.6.3",
    "mouse-helper": "^1.0.7",
    "pinia": "^3.0.4",
    "vue": "^3.5.27",
    "vue-router": "^5.0.2",
    "whatamesh": "^0.2.0"
  },
  "devDependencies": {
    "@pinia/testing": "^1.0.3",
    "@playwright/test": "^1.58.1",
    "@tailwindcss/vite": "^4.1.18",
    "@types/node": "^25.2.0",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "@vue/test-utils": "^2.4.6",
    "happy-dom": "^20.5.0",
    "playwright": "^1.58.0",
    "prettier": "^3.8.1",
    "swagger-typescript-api": "^13.2.16",
    "tailwindcss": "^4.0.15",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18",
    "vue-tsc": "^3.2.4"
  }
}
