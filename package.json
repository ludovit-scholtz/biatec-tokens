{
  "name": "biatec-tokens-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "generate-api": "swagger-typescript-api generate -p https://api.tokens.biatec.io/swagger/v1/swagger.json -o src/generated -n ApiClient.ts --axios",
    "check-typescript-errors-tsc": "npx tsc --noEmit --project tsconfig.app.json",
    "check-typescript-errors-vue": "npx vue-tsc --noEmit --project tsconfig.app.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "test:e2e:journey-video": "set VIDEO_RECORDING=true && playwright test full-e2e-journey.spec.ts --grep \"should complete full journey\" --config playwright-video.config.ts"
  },
  "dependencies": {
    "@algorandfoundation/algokit-utils": "^9.2.0",
    "@heroicons/vue": "^2.2.0",
    "algosdk": "^3.5.2",
    "arc14": "^1.0.4",
    "arc76": "^1.0.2",
    "axios": "^1.14.0",
    "buffer": "^6.0.3",
    "mouse-helper": "^1.0.7",
    "pinia": "^3.0.4",
    "vue": "^3.5.31",
    "vue-router": "^5.0.4",
    "whatamesh": "^0.2.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@pinia/testing": "^1.0.3",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^25.5.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitest/coverage-v8": "^4.1.2",
    "@vitest/ui": "^4.1.2",
    "@vue/test-utils": "^2.4.6",
    "ghost-cursor-playwright": "^2.1.0",
    "happy-dom": "^20.8.9",
    "playwright": "^1.58.0",
    "prettier": "^3.8.1",
    "swagger-typescript-api": "^13.6.5",
    "tailwindcss": "^4.2.1",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.2",
    "vue-tsc": "^3.2.6"
  }
}
