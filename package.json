{
  "name": "biatec-tokens-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "generate-api": "swagger-typescript-api generate -p https://api.tokens.biatec.io/swagger/v1/swagger.json -o src/generated -n ApiClient.ts --axios",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test --reporter=line",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report"
  },
  "dependencies": {
    "@agoralabs-sh/avm-web-provider": "^1.7.0",
    "@algorandfoundation/algokit-utils": "^9.2.0",
    "@blockshake/defly-connect": "^1.2.1",
    "@heroicons/vue": "^2.2.0",
    "@perawallet/connect": "^1.4.2",
    "@txnlab/use-wallet-vue": "^4.4.0",
    "@walletconnect/modal": "^2.7.0",
    "@walletconnect/sign-client": "^2.23.4",
    "algorand-authentication-component-vue": "^2.0.6",
    "algosdk": "^3.5.2",
    "axios": "^1.13.3",
    "buffer": "^6.0.3",
    "lute-connect": "^1.6.3",
    "pinia": "^3.0.4",
    "vue": "^3.5.27",
    "vue-router": "^4.6.4",
    "whatamesh": "^0.2.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.0",
    "@tailwindcss/vite": "^4.0.15",
    "@types/node": "^25.0.9",
    "@vitejs/plugin-vue": "^6.0.3",
    "@vitest/coverage-v8": "^4.0.17",
    "@vitest/ui": "^4.0.17",
    "@vue/test-utils": "^2.4.6",
    "happy-dom": "^20.3.9",
    "playwright": "^1.58.0",
    "prettier": "^3.8.0",
    "swagger-typescript-api": "^13.1.2",
    "tailwindcss": "^4.0.15",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18",
    "vue-tsc": "^3.2.4"
  }
}
